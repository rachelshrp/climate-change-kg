<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://climate-change.org/kg/swrl"
         xmlns="http://climate-change.org/kg/swrl#">

<owl:Ontology rdf:about="http://climate-change.org/kg/swrl"/>

<owl:ObjectProperty rdf:about="#locatedIn">
  <rdfs:domain rdf:resource="#Organization"/>
  <rdfs:range rdf:resource="#GeopoliticalEntity"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#signedBy">
  <rdfs:domain rdf:resource="#Agreement"/>
  <rdfs:range rdf:resource="#GeopoliticalEntity"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Organization">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#GeopoliticalEntity">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Agreement">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#PolicyLinkedOrg">
  <rdfs:subClassOf rdf:resource="#Organization"/>
</owl:Class>


</rdf:RDF>
