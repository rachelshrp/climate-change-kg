@prefix cc: <http://climate-change.org/kg/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cc:affiliatedWith a owl:ObjectProperty ;
    rdfs:label "affiliatedWith"@en ;
    rdfs:domain cc:Person ;
    rdfs:range cc:Organization .

cc:confidenceScore a owl:DatatypeProperty ;
    rdfs:label "confidenceScore"@en ;
    rdfs:range xsd:float .

cc:hasYear a owl:DatatypeProperty ;
    rdfs:label "hasYear"@en ;
    rdfs:domain cc:Date ;
    rdfs:range xsd:integer .

cc:locatedIn a owl:ObjectProperty ;
    rdfs:label "locatedIn"@en ;
    rdfs:domain cc:Organization ;
    rdfs:range cc:GeopoliticalEntity .

cc:occursIn a owl:ObjectProperty ;
    rdfs:label "occursIn"@en ;
    rdfs:domain cc:ClimateEvent ;
    rdfs:range cc:GeopoliticalEntity .

cc:ontology a owl:Ontology ;
    rdfs:label "Climate Change Knowledge Graph Ontology"@en .

cc:signedBy a owl:ObjectProperty ;
    rdfs:label "signedBy"@en ;
    rdfs:domain cc:Agreement ;
    rdfs:range cc:GeopoliticalEntity .

cc:Agreement a owl:Class ;
    rdfs:label "Agreement"@en ;
    rdfs:comment "An international treaty or agreement related to climate policy."@en ;
    rdfs:subClassOf cc:Organization .

cc:ClimateEvent a owl:Class ;
    rdfs:label "ClimateEvent"@en ;
    rdfs:comment "A climate-related phenomenon or event such as a heatwave or flood."@en ;
    rdfs:subClassOf owl:Thing .

cc:Date a owl:Class ;
    rdfs:label "Date"@en ;
    rdfs:comment "A concrete temporal reference such as a year or dated event."@en .

cc:Person a owl:Class ;
    rdfs:label "Person"@en ;
    rdfs:comment "A human individual involved in climate change research or policy."@en .

cc:GeopoliticalEntity a owl:Class ;
    rdfs:label "GeopoliticalEntity"@en ;
    rdfs:comment "A country, region, or political territory."@en .

cc:Organization a owl:Class ;
    rdfs:label "Organization"@en ;
    rdfs:comment "An institution, agency, or body related to climate change."@en .

